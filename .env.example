# Banco de dados
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/craftmind_db"

# JWT — mínimo 32 caracteres cada
JWT_SECRET="seu_segredo_de_access_token_minimo_32_caracteres"
JWT_REFRESH_SECRET="seu_segredo_de_refresh_token_minimo_32_caracteres"

# Upstash Redis — obtenha em https://upstash.com
UPSTASH_REDIS_REST_URL="https://SEU_ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="SEU_TOKEN_UPSTASH"

# Socket.io — URL do servidor dedicado (porta 3001 por padrão)
SOCKET_SERVER_URL="http://localhost:3001"

# URL pública exposta ao browser (prefixo NEXT_PUBLIC_ é intencional)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# Cloudinary — obtenha em https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SOCKET_INTERNAL_SECRET="internal-secret-for-socket-io-communication"
