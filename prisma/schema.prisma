// ============================================================
// Craft Mind — Prisma Schema
// Versão inicial cobrindo Fases 2–8 do roadmap
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum HabitCategory {
  PHYSICAL // Físicos — Ataque Físico, Defesa Física, Vida
  INTELLECTUAL // Intelectuais — Ataque Mágico + chance de habilidade
  MENTAL // Mentais — Defesa Mágica, Velocidade
  SOCIAL // Sociais — a definir
  SPIRITUAL // Espirituais — a definir
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum BattleStatus {
  WAITING // aguardando oponente
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum HouseName {
  ARION // Leão — Físicos
  LYCUS // Lobo — Físicos + Intelectual + Mental
  NOCTIS // Coruja — Intelectual + Espiritual
  NEREID // Sereia — Social + Mental
}

enum CardRarity {
  COMUM // Tier 1
  INCOMUM // Tier 2
  RARO // Tier 3
  EPICO // Tier 4
  LENDARIO // Tier 5
}

// ============================================================
// HOUSE — Casas do jogo (seed: 4 registros fixos)
// ============================================================

model House {
  id          String    @id @default(cuid())
  name        HouseName @unique
  animal      String // ex: "Leão"
  description String // essência da casa
  users       User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// USER — Jogador
// ============================================================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String  @unique
  avatarUrl    String?
  houseId      String?

  house      House?      @relation(fields: [houseId], references: [id])
  character  Character?
  habits     UserHabit[]
  habitLogs  HabitLog[]
  dailyTasks DailyTask[]

  // Batalhas em que o usuário participou
  battlesAsPlayer1       Battle[]                @relation("BattlePlayer1")
  battlesAsPlayer2       Battle[]                @relation("BattlePlayer2")
  battlesWon             Battle[]                @relation("BattleWinner")
  pveBattles             PveBattle[]
  refreshTokens          RefreshToken[]
  coopParticipations     CoopBattleParticipant[]
  teamBattleParticipants TeamBattleParticipant[]

  // Amizades
  sentFriendRequests     Friendship[] @relation("FriendshipSender")
  receivedFriendRequests Friendship[] @relation("FriendshipReceiver")

  // Cristais de Memoria + Bestiario
  userCards               UserCard[]
  mobKillStats            MobKillStat[]
  pendingCardDuplicates   PendingCardDuplicate[]
  spectralDropLogs        SpectralDropLog[]
  showcase                UserShowcase?

  // Logs de login (anti multi-account)
  loginLogs LoginLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// LOGIN LOG — Registro de cada login (anti multi-account)
// ============================================================
// Append-only: nunca atualizado. Sem createdAt/updatedAt por design.
// Retencao 90 dias via lib/jobs/cleanup-login-log.ts.
// onDelete: Cascade — delete da conta apaga todos os logs (LGPD).

model LoginLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitorId  String // FingerprintJS visitorId, ou "unknown" se cliente nao enviou
  ip         String
  userAgent  String   @db.VarChar(500)
  loggedInAt DateTime @default(now())

  @@index([userId, loggedInAt])
  @@index([visitorId, loggedInAt])
}

// ============================================================
// FRIENDSHIP — Relação de amizade entre dois jogadores
// ============================================================

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)

  sender   User @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId])
}

// ============================================================
// REFRESH TOKEN — Tokens de refresh persistidos (rotação segura)
// ============================================================

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  family    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([family])
  @@index([expiresAt])
}

// ============================================================
// CHARACTER — Atributos do personagem (1-1 com User)
// ============================================================

model Character {
  id          String @id @default(cuid())
  userId      String @unique
  physicalAtk Int    @default(10) // Ataque Físico
  physicalDef Int    @default(10) // Defesa Física
  magicAtk    Int    @default(10) // Ataque Mágico
  magicDef    Int    @default(10) // Defesa Mágica
  hp          Int    @default(100) // Pontos de Vida máximos
  speed       Int    @default(10) // Velocidade (ordem de turno)
  level       Int    @default(1)
  currentExp  Int    @default(0)
  freePoints  Int    @default(0)
  bossEssence Int    @default(0)

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterSkills CharacterSkill[]
  pvpStats        PvpStats[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// HABIT — Definição de um hábito (seed: lista base por categoria)
// ============================================================

model Habit {
  id          String        @id @default(cuid())
  name        String        @unique
  description String        @default("")
  category    HabitCategory

  logs       HabitLog[]
  users      UserHabit[]
  dailyTasks DailyTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// USER HABIT — Hábitos selecionados pelo usuário no cadastro (N-N)
// ============================================================

model UserHabit {
  id      String @id @default(cuid())
  userId  String
  habitId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, habitId])
}

// ============================================================
// HABIT LOG — Registro diário de hábito cumprido
// ============================================================

model HabitLog {
  id      String @id @default(cuid())
  userId  String
  habitId String

  // Snapshot dos atributos concedidos no momento do registro
  // (o Habit.attributeGrants pode mudar; este é o valor histórico real)
  attributesGranted Json

  completedAt DateTime @default(now())

  // Meia-noite UTC do dia da conclusão — usado na constraint unique
  date DateTime @db.Date

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit     Habit    @relation(fields: [habitId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Um usuário não pode registrar o mesmo hábito mais de uma vez por dia
  @@unique([userId, habitId, date])
  // Acelera groupBy(userId) + filtros de date range usados pelo ranking de habitos
  @@index([userId, date])
}

// ============================================================
// SKILL — Habilidade desbloqueável
// ============================================================

model Skill {
  id          String @id @default(cuid())
  name        String @unique
  description String
  tier        Int
  cooldown    Int    @default(0) // 0 = sem cooldown, 1 = 1 turno, 2 = 2 turnos
  target      String
  damageType  String
  basePower   Int
  hits        Int    @default(1)
  accuracy    Int    @default(100)
  effects     Json   @default("[]")
  mastery     Json   @default("{}")

  characterSkills CharacterSkill[]
  mobSkills       MobSkill[]
  bossSkills      BossSkill[]

  // Cristais Espectrais (purity 100) que escolheram esta skill como 5o slot.
  userCardsSpectral UserCard[] @relation("UserCardSpectralSkill")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// CHARACTER SKILL — Relação N-N entre Character e Skill
// ============================================================

model CharacterSkill {
  id          String  @id @default(cuid())
  characterId String
  skillId     String
  equipped    Boolean @default(false) // máximo 4 equipadas por personagem
  slotIndex   Int? // 0–3 quando equipped = true

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skill     Skill     @relation(fields: [skillId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, skillId])
  @@unique([characterId, slotIndex]) // dois skills não podem ocupar o mesmo slot
}

// ============================================================
// DAILY TASK — Tarefa diária gerada a partir de um hábito
// ============================================================

model DailyTask {
  id              String    @id @default(cuid())
  userId          String
  habitId         String
  description     String // ex: "Faça 3 séries de flexões"
  tag             String?
  attributeGrants Json // { physicalAttack?: number, physicalDefense?: number, magicAttack?: number, magicDefense?: number, hp?: number, speed?: number }
  dueDate         DateTime // dia para o qual a tarefa foi gerada
  completed       Boolean   @default(false)
  completedAt     DateTime? // null até ser completada

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, description, dueDate])
  @@index([userId, dueDate])
}

// ============================================================
// BATTLE — Registro de uma batalha
// ============================================================

model Battle {
  id        String       @id @default(cuid())
  player1Id String
  player2Id String
  winnerId  String?
  status    BattleStatus @default(WAITING)

  // Array de objetos descrevendo cada turno:
  // [{ turn: 1, actorId: "...", skillId: "...", damage: 45, targetHpAfter: 55 }, ...]
  log Json @default("[]")

  player1 User  @relation("BattlePlayer1", fields: [player1Id], references: [id])
  player2 User  @relation("BattlePlayer2", fields: [player2Id], references: [id])
  winner  User? @relation("BattleWinner", fields: [winnerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([player1Id])
  @@index([player2Id])
  @@index([status])
}

// ============================================================
// MOB — Inimigo PvE controlado por IA
// ============================================================

model Mob {
  id           String  @id @default(cuid())
  name         String  @unique
  description  String
  loreExpanded String?
  curiosity    String?
  tier         Int
  aiProfile    String
  imageUrl     String?
  // 1 = mob comum (nunca varia); 2 ou 3 = pode aparecer em versao Heroi/Lendaria com stats escalados
  maxStars     Int     @default(1)

  physicalAtk Int
  physicalDef Int
  magicAtk    Int
  magicDef    Int
  hp          Int
  speed       Int

  skills       MobSkill[]
  pveBattles   PveBattle[]
  cards        Card[]
  mobKillStats MobKillStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// MOB SKILL — Relacao N-N entre Mob e Skill (4 skills por mob)
// ============================================================

model MobSkill {
  id        String @id @default(cuid())
  mobId     String
  skillId   String
  slotIndex Int

  mob   Mob   @relation(fields: [mobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([mobId, skillId])
  @@unique([mobId, slotIndex])
}

// ============================================================
// PVE BATTLE — Registro de uma batalha PvE contra mob
// ============================================================

enum PveBattleMode {
  SOLO
  MULTI
  COOP_2V3
  COOP_2V5
  COOP_3V5
}

model PveBattle {
  id         String        @id @default(cuid())
  userId     String
  mobId      String
  result     String?
  expGained  Int           @default(0)
  turns      Int           @default(0)
  log        Json          @default("[]")
  mode       PveBattleMode @default(SOLO)
  teamMateId String?
  mobIds     String[]      @default([])

  user User @relation(fields: [userId], references: [id])
  mob  Mob  @relation(fields: [mobId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ============================================================
// BOSS — Chefe cooperativo por categoria de hábito
// ============================================================

model Boss {
  id          String        @id @default(cuid())
  name        String        @unique
  description String
  lore        String
  category    HabitCategory
  tier        Int
  aiProfile   String

  physicalAtk Int
  physicalDef Int
  magicAtk    Int
  magicDef    Int
  hp          Int
  speed       Int

  skills      BossSkill[]
  coopBattles CoopBattle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// BOSS SKILL — Relacao N-N entre Boss e Skill (4 skills por boss)
// ============================================================

model BossSkill {
  id        String @id @default(cuid())
  bossId    String
  skillId   String
  slotIndex Int

  boss  Boss  @relation(fields: [bossId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([bossId, skillId])
  @@unique([bossId, slotIndex])
}

// ============================================================
// COOP BATTLE — Registro de uma batalha cooperativa contra boss
// ============================================================

model CoopBattle {
  id        String   @id @default(cuid())
  bossId    String
  date      DateTime @db.Date
  status    String   @default("MATCHING")
  result    String?
  turns     Int      @default(0)
  expGained Int      @default(0)
  log       Json     @default("[]")

  boss         Boss                    @relation(fields: [bossId], references: [id])
  participants CoopBattleParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date, status])
}

// ============================================================
// COOP BATTLE PARTICIPANT — Jogador participante de uma batalha coop
// ============================================================

model CoopBattleParticipant {
  id               String        @id @default(cuid())
  coopBattleId     String
  userId           String
  dominantCategory HabitCategory

  coopBattle CoopBattle @relation(fields: [coopBattleId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([coopBattleId, userId])
  @@index([userId])
}

// ============================================================
// PVP MODE — Modos de PvP (stats separados por modo)
// ============================================================

enum PvpMode {
  SOLO_1V1
  TEAM_2V2
  TEAM_3V3
  TEAM_5V5
}

// ============================================================
// PVP STATS — Estatísticas de PvP por modo (W/L/D + ranking)
// ============================================================

model PvpStats {
  id            String  @id @default(cuid())
  characterId   String
  mode          PvpMode
  wins          Int     @default(0)
  losses        Int     @default(0)
  draws         Int     @default(0)
  rankingPoints Int     @default(0)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, mode])
  @@index([mode, rankingPoints])
}

// ============================================================
// TEAM BATTLE — Registro de batalha em equipe (2v2, 3v3, 5v5)
// ============================================================

model TeamBattle {
  id         String       @id @default(cuid())
  mode       PvpMode
  winnerTeam Int? // 1, 2, ou null (empate)
  status     BattleStatus @default(IN_PROGRESS)
  turns      Int          @default(0)
  log        Json         @default("[]")

  participants TeamBattleParticipant[]

  createdAt  DateTime  @default(now())
  finishedAt DateTime?
}

// ============================================================
// TEAM BATTLE PARTICIPANT — Jogador em batalha de equipe
// ============================================================

model TeamBattleParticipant {
  id           String @id @default(cuid())
  teamBattleId String
  userId       String
  characterId  String
  team         Int // 1 ou 2

  teamBattle TeamBattle @relation(fields: [teamBattleId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([teamBattleId, userId])
  @@index([userId])
}

// ============================================================
// CARD — Cristal de Memoria (1 por mob, drop pos-batalha)
// ============================================================

model Card {
  id                 String     @id @default(cuid())
  mobId              String
  name               String     @unique
  flavorText         String
  rarity             CardRarity
  // URL Cloudinary da arte da carta (separada da imageUrl do mob).
  // Pode ser null enquanto o asset nao foi gerado/uploaded.
  cardArtUrl         String?
  // URL Cloudinary da arte alternativa exclusiva da versao Espectral
  // (purity === 100). Quando null, o frontend faz fallback para `cardArtUrl`
  // com filtro CSS holografico (hue-rotate + saturate).
  cardArtUrlSpectral String?
  // Array tipado de CardEffect (validado em lib/validations/cards.ts).
  // Ver types/cards.ts para o discriminated union: STAT_FLAT | STAT_PERCENT | TRIGGER | STATUS_RESIST.
  effects            Json       @default("[]")
  // 0-100, percentual individual de drop quando a variante e elegivel
  dropChance         Float      @default(5)
  // Estrela minima do encontro para esta variante cair (1, 2 ou 3)
  requiredStars      Int        @default(1)

  mob       Mob        @relation(fields: [mobId], references: [id], onDelete: Cascade)
  userCards UserCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mobId, requiredStars])
}

// ============================================================
// USER CARD — Copia de cristal pertencente a um usuario
// ============================================================

model UserCard {
  id        String  @id @default(cuid())
  userId    String
  cardId    String
  equipped  Boolean @default(false)
  slotIndex Int? // 0, 1 ou 2 quando equipped = true; null caso contrario
  xp        Int     @default(0) // XP acumulado por duplicatas (50/100/200/400/800 por raridade)
  level     Int     @default(1) // 1-5; afeta multiplicador de effects (1.0/1.2/1.4/1.6/1.8)
  purity    Int     @default(50) // 0-100, escala efeitos via purity/50 (50 = 1.0x baseline)

  // Skill espectral escolhida pelo dono. So aplica quando purity === 100
  // (Cristal Espectral). Habilita o 5o slot de skill em batalha. A skill DEVE
  // pertencer aos 4 mob skills do mob de origem (validado via MobSkill na rota
  // PUT /api/cards/[id]/spectral-skill). onDelete: SetNull garante que se a
  // Skill referenciada for removida do banco, a UserCard nao quebra — o 5o
  // slot apenas desaparece silenciosamente na proxima batalha.
  spectralSkillId String?
  spectralSkill   Skill?  @relation("UserCardSpectralSkill", fields: [spectralSkillId], references: [id], onDelete: SetNull)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  pendingDuplicates PendingCardDuplicate[]
  spectralDropLogs  SpectralDropLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Politica de duplicata: primeira copia cria UserCard; duplicatas viram xp/level.
  @@unique([userId, cardId])
  // Dois cristais nao podem ocupar o mesmo slot do mesmo usuario.
  @@unique([userId, slotIndex])
  @@index([userId])
  @@index([spectralSkillId])
}

// ============================================================
// PENDING CARD DUPLICATE — Drop de duplicata com purity MAIOR aguardando decisao
// ============================================================
//
// Quando o jogador dropa uma copia de uma carta que ja possui e a nova copia
// tem `purity` maior que a atual, o sistema cria uma pendencia (em vez de
// converter automaticamente em XP). O jogador resolve via UI escolhendo:
//   - REPLACE: zera xp/level da UserCard atual e adota a nova purity
//   - CONVERT: aplica XP normal via applyXpGain (mantem purity atual)
//
// Pendencias acumulam sem expiracao. Cascade nas duas relacoes garante limpeza
// se o User ou a UserCard for deletado.

model PendingCardDuplicate {
  id         String   @id @default(cuid())
  userId     String
  userCardId String
  newPurity  Int // 0-100, purity rolada na nova copia

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userCard UserCard @relation(fields: [userCardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userCardId])
}

// ============================================================
// MOB KILL STAT — Projecao agregada de kills/derrotas por user/mob
//                 (alimenta o bestiario evolutivo)
// ============================================================

model MobKillStat {
  id          String   @id @default(cuid())
  userId      String
  mobId       String
  victories   Int      @default(0)
  defeats     Int      @default(0)
  damageDealt Int      @default(0)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mob  Mob  @relation(fields: [mobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mobId])
  @@index([userId])
  @@index([mobId])
}

// ============================================================
// SPECTRAL DROP LOG — Append-only de drops com purity 100 (Espectral)
// ============================================================
//
// Registro historico de cada Cristal Espectral dropado, alimenta feed/admin
// futuros (ranking de Espectrais, hall da fama). Append-only: nunca atualizado.
// Cascade nas duas relacoes para limpeza automatica.

model SpectralDropLog {
  id         String   @id @default(cuid())
  userId     String
  userCardId String
  droppedAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userCard UserCard @relation(fields: [userCardId], references: [id], onDelete: Cascade)

  @@index([droppedAt])
  @@index([userId])
}

// ============================================================
// USER SHOWCASE — Vitrine de cristais escolhidos para exibir no perfil publico
// ============================================================
//
// Ate 6 UserCardIds escolhidos pelo dono. Validacao do limite e da ownership
// e feita na camada de aplicacao (PUT /api/user/showcase). Ordem do array
// e preservada na renderizacao da vitrine. Sem expiracao.
//
// Relacao 1-1 com User (constraint unique em userId). Espectrais aparecem com
// destaque visual (glow dourado) na pagina /character/[id]/showcase.

model UserShowcase {
  id          String   @id @default(cuid())
  userId      String   @unique
  userCardIds String[] @default([])
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
